{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": false,
  "singleQuote": true,
  "singleAttributePerLine": true,
  "sortImports": {
    "newlinesBetween": false,
    "groups": [
      "type",
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown",
      ["side_effect", "side_effect_style"]
    ]
  }
}
